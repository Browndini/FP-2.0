rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users: read/write own doc only
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Pets: own read/write; anyone can read public pets
      match /pets/{petId} {
        allow read: if (request.auth != null && request.auth.uid == uid)
                    || resource.data.isPublic == true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Inventory: own read only; writes come from Cloud Functions (admin SDK)
      match /inventory/{itemId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // Usernames index: public read for profile lookups; writes via Cloud Functions only
    match /usernames/{username} {
      allow read: if true;
      allow write: if false;
    }

    // Species catalog: public read, no client writes
    match /species/{speciesId} {
      allow read: if true;
      allow write: if false;
    }

    // Mini-game sessions: owner read only; all writes via Cloud Functions
    match /miniGameSessions/{sessionId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
