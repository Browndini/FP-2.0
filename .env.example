# Copy to .env.local and fill in values from Firebase Console → Project settings → Your apps → Web app.
# See docs/FIREBASE_SETUP.md for full setup instructions.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Stripe IAP — set on Cloud Functions via `firebase functions:secrets:set` (not in .env.local):
# STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET
# STRIPE_PRICE_NEBULA_CAPE, STRIPE_PRICE_AURORA_HALO, STRIPE_PRICE_CELESTIAL_WINGS
